{
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    { "source": "/work", "destination": "/work/index.html" },
    { "source": "/about", "destination": "/about/index.html" },
    { "source": "/contact", "destination": "/contact/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
